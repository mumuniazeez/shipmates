generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  hcId         String   @unique
  email        String   @unique
  slackId      String?  @unique
  firstName    String?
  lastName     String?
  yswsEligible Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
