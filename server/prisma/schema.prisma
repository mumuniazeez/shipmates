generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  hcId         String   @unique
  email        String   @unique
  slackId      String?  @unique
  profileImg   String?
  firstName    String?
  lastName     String?
  bio          String?
  yswsEligible Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  projectPitches        ProjectPitch[]
  matchesAsOwner        Match[]        @relation("matchProjectOwner")
  matchesAsCollaborator Match[]        @relation("matchMatchingUser")

  @@map("users")
}

model ProjectPitch {
  id              String   @id @default(uuid())
  title           String
  description     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  yswsProgramName String?

  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  userId       String
  skillsNeeded Skill[]
  matches      Match[]

  @@map("project_pitches")
}

model Skill {
  id             String         @id @default(uuid())
  name           String         @unique
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  projectPitches ProjectPitch[]

  @@map("skills")
}

model Match {
  id                  String        @id @default(uuid())
  projectOwner        User          @relation("matchProjectOwner", fields: [projectOwnerId], references: [id])
  projectOwnerId      String
  collaboratingUser   User          @relation("matchMatchingUser", fields: [collaboratingUserId], references: [id])
  collaboratingUserId String        @map("matchingUserId")
  projectPitch        ProjectPitch? @relation(fields: [projectPitchId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  projectPitchId      String?

  @@map("matches")
}
