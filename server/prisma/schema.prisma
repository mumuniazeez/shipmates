generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  hcId         String   @unique
  email        String   @unique
  slackId      String?  @unique
  profileImg   String?
  firstName    String?
  lastName     String?
  bio          String?
  yswsEligible Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  projectPitches ProjectPitch[]

  @@map("users")
}

model ProjectPitch {
  id          String   @id @default(cuid())
  title       String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  userId      String?

  @@map("project_pitches")
}
